<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_fbr_monthly_return_template">
        <t t-call="web.html_container">
             <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <style>
                        .fbr-header { background: #1a5276; color: white; padding: 20px; text-align: center; border-radius: 5px; margin-bottom: 25px; }
                        .return-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
                        .return-table th { background: #2e86c1; color: white; padding: 10px; border: 1px solid #ddd; }
                        .return-table td { padding: 10px 12px; border: 1px solid #ddd; font-size: 13px; }
                        .return-table .net-row { background: #d5e8d4; font-weight: bold; font-size: 15px; }
                        .return-table .output-row { background: #fef9e7; }
                        .return-table .input-row { background: #eaf4fb; }
                        .text-right { text-align: right; }
                        .summary-box { border: 2px solid #1a5276; border-radius: 8px; padding: 15px; margin-top: 20px; }
                        .stamp-box { border: 3px solid #c0392b; color: #c0392b; padding: 10px 20px; display: inline-block; transform: rotate(-5deg); font-size: 18px; font-weight: bold; float: right; margin-top: -60px; }
                    </style>

                    <div class="fbr-header">
                        <h3 style="margin:5px 0;">MONTHLY SALES TAX RETURN</h3>
                    </div>

                    <!-- Main Return Table -->
                    <h4 style="color:#1a5276;">SALES TAX RETURN SUMMARY</h4>
                    <table class="return-table">
                        <thead>
                            <tr>
                                <th style="width:60%;">Particulars</th>
                                <th style="width:40%;" class="text-right">Amount (PKR)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="output-row">
                                <td>
                                    <strong>A. Output Tax</strong><br/>
                                </td>
                                <td class="text-right">
                                    <strong><t t-esc="'{:,.2f}'.format(doc.output_tax)"/></strong>
                                </td>
                            </tr>
                            <tr class="input-row">
                                <td>
                                    <strong>B. Input Tax</strong><br/>
                                </td>
                                <td class="text-right">
                                    <strong><t t-esc="'{:,.2f}'.format(doc.input_tax)"/></strong>
                                </td>
                            </tr>
                            <tr class="net-row">
                                <td>
                                    NET TAX PAYABLE<br/>
                                </td>
                                <td class="text-right">
                                    <t t-esc="'{:,.2f}'.format(doc.net_tax_payable)"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                </div>
             </t>
        </t>
    </template>

    <record id="action_report_fbr_monthly_return" model="ir.actions.report">
        <field name="name">FBR Monthly Tax Return</field>
        <field name="model">fbr.tax.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">fbr_sales_tax.report_fbr_monthly_return_template</field>
        <field name="report_file">fbr_sales_tax.report_fbr_monthly_return_template</field>
        <field name="print_report_name">'FBR_Monthly_Return_%s_%s' % (object.date_from, object.date_to)</field>
    </record>

</odoo>
