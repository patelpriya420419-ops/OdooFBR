<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vat_report_wizard_form" model="ir.ui.view">
        <field name="name">vat.report.wizard.form</field>
        <field name="model">vat.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Saudi VAT Report">
                <group><field name="amount"/></group>
                <footer>
                    <button name="action_print_report" string="Print Report" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_vat_report_wizard" model="ir.actions.act_window">
        <field name="name">Saudi VAT Report</field>
        <field name="res_model">vat.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_saudi_vat_report" name="Saudi VAT Report" action="action_vat_report_wizard"/>
</odoo>